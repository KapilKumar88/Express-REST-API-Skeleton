APP_NAME=node-skeleton
APP_URL=http://localhost:3000
NODE_ENV=local
PORT=3000

FRONT_END_APP_URL=http://localhost:5173

# DB
MONGO_CONNECTION_STRING=mongodb://localhost:27017/node-skeleton

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. JWT_SECRET and JWT_REFRESH_TOKEN_SECRET must differ.
JWT_SECRET=<min-32-char-random-string>
JWT_EXPIRE_TIME=30
JWT_REFRESH_TOKEN_SECRET=<different-min-32-char-random-string>
JWT_REFRESH_TOKEN_EXPIRE_TIME=90

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=<64-char-hex-string>

# Account lockout (optional — safe defaults apply if omitted)
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30

# Winston log rotation (all optional — safe defaults apply if omitted)
WINSTON_LOG_FILE_NAME=app-%DATE%.log
WINSTON_LOG_DIR_NAME=logs
WINSTON_ZIP_ARCHIVE=true
WINSTON_MAX_SIZE=20m
WINSTON_MAX_FILE=14d

# Mail (all required — app will refuse to boot without these)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=<smtp-password>
MAIL_SECURE=false
MAIL_FROM_ADDRESS=no-reply@example.com


# excryption secret and algorithm
ENCRYPTION_ALGORITHM=AES-256-CBC
ENCRYPTION_SECRET=<64-char-hex-string>